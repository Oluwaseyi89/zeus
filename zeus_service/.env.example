# Example environment variables for zeus_service (backend)
# Copy this to `.env` and fill real secrets for production.

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── API / Security ──────────────────────────────────────────────────────────
API_KEY=dev-api-key
ADMIN_API_KEY=admin-api-key
JWT_SECRET=dev-jwt-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_URL=postgres://user:password@localhost:5432/zeus_dev

# ─── Redis / Queue ───────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── Starknet ────────────────────────────────────────────────────────────────
STARKNET_RPC_URL=http://127.0.0.1:5050
STARKNET_ACCOUNT_PRIVATE_KEY=
STARKNET_ACCOUNT_ADDRESS=

# ─── Bitcoin RPC (e.g. regtest/bitcoind) ────────────────────────────────────
BITCOIN_RPC_URL=http://127.0.0.1:18443

# ─── Stellar (Soroban) ──────────────────────────────────────────────────────
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_FACTORY_CONTRACT_ID=CBAISPE5ZXRENN3CTXRA4TU4GY5C7BN46YECCHRPFFP4ZGS5IAN4DSBA
STELLAR_VERIFIER_CONTRACT_ID=CCS2Q3LYJLW3HOUVZE7BHBJU6KDPCB6Z7T4Z7IMSZJLOJFC6A2TFA5XT
STELLAR_TOKEN_CONTRACT_ID=your_token_contract_id
STELLAR_TREASURY_ADDRESS=your_treasury_address
STELLAR_OPERATOR_SECRET=your_operator_secret_key
STELLAR_FEE_BPS=50

# ─── Swap Escrow (optional override) ────────────────────────────────────────
SWAP_ESCROW_ADDRESS=0x<ESCROW_CONTRACT_ADDRESS>

# ─── Dev flags ──────────────────────────────────────────────────────────────
DEV_STORE_SECRETS=true
DISABLE_WATCHTOWER=false

# ─── Notifications / Queue ──────────────────────────────────────────────────
ENABLE_NOTIFICATION_QUEUE=true
ENABLE_NOTIFICATION_RETRY=true
NOTIFICATION_MAX_RETRY_ATTEMPTS=5
NOTIFICATION_RETRY_INTERVAL_MS=15000

# ─── SMTP (optional) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# ─── SMS provider (optional) ────────────────────────────────────────────────
SMS_API_URL=

# ─── Other ──────────────────────────────────────────────────────────────────
# Add additional vars here as needed